      "file": "full_mix_01/full_mix_01.wav",
      "split": "regression",
      "expected_issue": ["muddy", "boomy", "dull"],
      "expected_source": ["vocal", "guitar", "bass", "drums", "keys"],
      "severity": "high",
      "label_quality": "unknown",
      "reviewer_notes": "Imported from existing per-sample metadata.json.",
      "recording_condition": {
