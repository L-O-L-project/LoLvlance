{
  "schema_version": "1.0.0",
  "dataset_version": "goldens-v0.1",
  "description": "Central manifest for LoLvlance golden audio labels. Existing labels come from per-sample metadata.json files. Unknown collection fields are intentionally not inferred.",
  "label_sets": {
    "issue_labels": ["muddy", "harsh", "buried", "boomy", "thin", "boxy", "nasal", "sibilant", "dull"],
    "source_labels": ["vocal", "guitar", "bass", "drums", "keys"],
    "severity_values": ["none", "low", "medium", "high", "unknown"],
    "quality_values": ["reviewed", "single_reviewer", "unreviewed", "synthetic", "unknown"]
  },
  "collection_targets": {
    "mvp_regression_min_samples": 30,
    "validation_min_samples": 250,
    "production_eval_min_samples": 1000,
    "issue_samples_per_class_validation": 25,
    "source_samples_per_class_validation": 40,
    "issue_samples_per_class_production": 100,
    "source_samples_per_class_production": 150
  },
  "samples": [
    {
